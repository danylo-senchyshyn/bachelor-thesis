@startuml architecture-monolith
skinparam rectangle {
    BackgroundColor #DDEEFF
    BorderColor #336699
    FontSize 13
}
skinparam database {
    BackgroundColor #FFFACD
    BorderColor #CC9900
}
skinparam component {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}
skinparam arrow {
    Color #555555
}
skinparam defaultFontSize 12

title Monolitická architektúra – rezervačný systém

actor "Client" as Client

rectangle "Spring Boot Application\n(Single JVM Process)" {
    component "User Module\nUserController / UserService\nUserRepository" as UserModule
    component "Reservation Module\nReservationController / ReservationService\nReservationRepository" as ReservationModule
    component "Payment Module\nPaymentController / PaymentService\nPaymentRepository" as PaymentModule
    component "Notification Module\nNotificationService\nNotificationLogRepository" as NotificationModule

    ReservationModule --> PaymentModule : direct method call\n@Transactional
    PaymentModule --> ReservationModule : updateStatus(PAID / PAYMENT_FAILED)
    PaymentModule --> NotificationModule : logNotification()
}

database "reservation_monolith_db\n(PostgreSQL)" as DB {
}

Client --> UserModule        : HTTP REST /api/users
Client --> ReservationModule : HTTP REST /api/reservations
Client --> PaymentModule     : HTTP REST /api/payments

UserModule        --> DB : JDBC / JPA
ReservationModule --> DB : JDBC / JPA
PaymentModule     --> DB : JDBC / JPA
NotificationModule --> DB : JDBC / JPA

note bottom of DB
  Jedna zdieľaná databáza:
  users, reservations, payments, notification_logs
end note

@enduml
