@startuml erd-reservation
entity "Reservation" {
    + id : BIGINT <<PK>>
    --
    user_id : BIGINT <<NOT NULL>>
    resource_id : BIGINT <<NOT NULL>>
    start_time : TIMESTAMP <<NOT NULL>>
    end_time : TIMESTAMP <<NOT NULL>>
    status : VARCHAR(20) <<NOT NULL>>
    .. Status values: ..
    CREATED | PAID | PAYMENT_FAILED | CANCELLED
}

entity "OutboxEvent" {
    + id : BIGINT <<PK>>
    --
    created_at : TIMESTAMP <<NOT NULL>>
    aggregate_type : VARCHAR(255) <<NOT NULL>>
    aggregate_id : BIGINT <<NOT NULL>>
    event_type : VARCHAR(255) <<NOT NULL>>
    payload : TEXT (JSON serialized event)
    status : VARCHAR(20) <<NOT NULL>>
    .. Status values: ..
    NEW | SENT | FAILED
    .. Index: ..
    @Index(columnList = "status")
}

note bottom of OutboxEvent
  Polled every 5s by OutboxEventPublisher.
  NEW events published to Kafka, then marked SENT.
  Ensures atomicity between DB write and Kafka publish.
end note

Reservation "1" -- "0..1" OutboxEvent : Creates on reservation creation\n(ReservationCreatedEvent)

@enduml
