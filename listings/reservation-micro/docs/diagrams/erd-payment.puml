@startuml erd-payment
entity "Payment" {
    + id : BIGINT <<PK>>
    --
    reservation_id : BIGINT <<UNIQUE, NOT NULL>>
    amount : DECIMAL(10,2) <<NOT NULL>>
    status : VARCHAR(20) <<NOT NULL>>
    created_at : TIMESTAMP <<NOT NULL>>
    .. Status values: ..
    CREATED | CONFIRMED | FAILED | CANCELLED
}

entity "OutboxEvent" {
    + id : BIGINT <<PK>>
    --
    created_at : TIMESTAMP <<NOT NULL>>
    aggregate_type : VARCHAR(255) <<NOT NULL>>
    aggregate_id : BIGINT <<NOT NULL>>
    event_type : VARCHAR(255) <<NOT NULL>>
    payload : TEXT (JSON serialized event)
    status : VARCHAR(20) <<NOT NULL>>
    .. Status values: ..
    NEW | SENT | FAILED
    .. Index: ..
    @Index(columnList = "status")
}

note bottom of OutboxEvent
  Polled every 5s by OutboxEventPublisher.
  On CONFIRMED: publishes PaymentConfirmedEvent.
  On FAILED: publishes PaymentFailedEvent.
end note

Payment "1" -- "0..2" OutboxEvent : Creates on confirm/fail\n(PaymentConfirmedEvent or PaymentFailedEvent)

@enduml
